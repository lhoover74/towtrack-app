<!DOCTYPE html>
<html>
<head>
  <title>Add Towing Company - TowTrack</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <a href="/dashboard">Dashboard</a>
    <a href="/vehicles">Vehicles</a>
    <a href="/properties">Properties</a>
    <a href="/towing-companies">Towing Companies</a>
    <a href="/reports">Reports</a>
    <form method="POST" action="/logout" style="display: inline;"><button type="submit">Logout</button></form>
  </nav>
  <h1>Add Towing Company</h1>
  <% if (error) { %>
    <p style="color: red;"><%= error %></p>
  <% } %>
  <form method="POST">
    <label>Name: <input type="text" name="name" required></label><br>
    <label>Phone: <input type="text" name="phone"></label><br>
    <label>Email: <input type="email" name="email"></label><br>
    <label>Dispatch Contact: <input type="text" name="dispatch_contact"></label><br>
    <label>Notes: <textarea name="notes"></textarea></label><br>
    <label>Active: <input type="checkbox" name="active" checked></label><br>
    <button type="submit">Add Towing Company</button>
  </form>
</body>
</html>